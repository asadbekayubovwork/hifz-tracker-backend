# Telegram backup sozlamalari — bu faylni "backup.env" deb nusxalang va to'ldiring.
#   cp backup.env.example backup.env
#
# @BotFather dan olingan bot tokeni:
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# Sizning shaxsiy chat id'ingiz (yoki guruh id'i). @userinfobot aytib beradi.
TELEGRAM_CHAT_ID=987654321
